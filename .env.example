# Supabase credentials
# Prerequisites:
#   1. Create a Supabase project at https://supabase.com
#   2. Run the following SQL in the Supabase SQL Editor to create the questions table:
#
#      create table questions (
#        id uuid default gen_random_uuid() primary key,
#        text text not null,
#        votes int default 0,
#        voter_ids text[] default '{}',
#        created_at timestamptz default now()
#      );
#
#   3. Apply the stored functions in the Supabase SQL Editor:
#
#      docs/sql/cast_vote.sql
#
#      Run this on both your prod and test projects.
#
#   4. Copy your Project URL and anon/public key from:
#      Project Settings → API → Project URL / Project API keys
#
# For tests: use a separate Supabase test project (not the same as production).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
